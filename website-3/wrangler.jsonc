{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "novaguard",
  "main": "./worker/index.js",
  "compatibility_date": "2026-07-19",
  // Astro builds to ./dist (Next.js used ./out). run_worker_first lets the
  // worker enforce the password gate before any static asset is served.
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true
  }
}
