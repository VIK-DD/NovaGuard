---
import { features } from "../data/features";
---

<section class="border-b border-line">
  <div class="mx-auto max-w-6xl px-6 py-20">
    <div class="grid gap-8 lg:grid-cols-[16rem_1fr] lg:gap-12">
      <div>
        <p data-reveal class="font-mono text-xs tracking-[0.14em] text-primary uppercase">
          What it does
        </p>
        <h2
          data-reveal
          class="mt-3 font-display text-2xl leading-tight font-semibold text-balance sm:text-3xl"
        >
          Everything a community needs, nothing it doesn't.
        </h2>
      </div>

      <dl data-reveal-group class="divide-y divide-line border-t border-line">
        {
          features.map((f, i) => (
            <div data-reveal-item class="group grid gap-2 py-6 sm:grid-cols-[3rem_1fr_auto] sm:items-baseline sm:gap-6">
              <dt class="font-mono text-xs text-ink-faint">{String(i + 1).padStart(2, "0")}</dt>
              <div>
                <p class="font-display text-lg font-semibold">{f.title}</p>
                <p class="mt-1.5 max-w-lg text-sm leading-relaxed text-ink-muted">{f.body}</p>
              </div>
              <p class="font-mono text-xs text-ink-faint transition-colors group-hover:text-primary sm:text-right">
                {f.tag}
              </p>
            </div>
          ))
        }
      </dl>
    </div>
  </div>
</section>
