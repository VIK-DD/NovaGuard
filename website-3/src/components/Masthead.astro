---
import Icon from "./Icon.astro";
---

<div class="border-b border-line">
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-2 text-[11px] tracking-[0.16em] text-ink-faint uppercase"
  >
    <time data-masthead-date></time>
    <button
      type="button"
      data-theme-toggle
      aria-label="Toggle dark mode"
      class="flex items-center gap-1.5 transition-colors hover:text-ink"
    >
      <span class="hidden items-center gap-1.5 dark:flex">
        <Icon name="sun" size={13} /> Day edition
      </span>
      <span class="flex items-center gap-1.5 dark:hidden">
        <Icon name="moon" size={13} /> Night edition
      </span>
    </button>
  </div>
</div>
<script>
  type ViewTransition = { ready: Promise<void>; finished: Promise<void> };
  type VTDocument = Document & {
    startViewTransition?: (cb: () => void) => ViewTransition;
  };

  function init() {
    const dateEl = document.querySelector("[data-masthead-date]");
    if (dateEl) {
      dateEl.textContent = new Intl.DateTimeFormat("en", {
        weekday: "long",
        month: "long",
        day: "numeric",
        year: "numeric",
      }).format(new Date());
    }

    const KEY = "ng-theme";
    const root = document.documentElement;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const setTheme = (light: boolean) => {
      root.dataset.theme = light ? "light" : "dark";
      localStorage.setItem(KEY, light ? "light" : "dark");
      document
        .querySelector('meta[name="theme-color"]')
        ?.setAttribute("content", light ? "#fbfbfe" : "#0a0a0c");
    };

    // Night ↔ day as a circular wipe that sweeps the new theme out from the
    // toggle. Uses the View Transitions API; older browsers / reduced-motion
    // fall back to an instant swap.
    document.querySelectorAll<HTMLElement>("[data-theme-toggle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const light = root.dataset.theme !== "light";
        const doc = document as VTDocument;
        if (reduce || typeof doc.startViewTransition !== "function") {
          setTheme(light);
          return;
        }
        const r = btn.getBoundingClientRect();
        const x = r.left + r.width / 2;
        const y = r.top + r.height / 2;
        const end = Math.hypot(
          Math.max(x, window.innerWidth - x),
          Math.max(y, window.innerHeight - y),
        );
        root.classList.add("theme-wipe");
        const transition = doc.startViewTransition(() => setTheme(light));
        transition.ready.then(() => {
          root.animate(
            {
              clipPath: [
                `circle(0px at ${x}px ${y}px)`,
                `circle(${end}px at ${x}px ${y}px)`,
              ],
            },
            {
              duration: 480,
              easing: "cubic-bezier(0.16, 1, 0.3, 1)",
              pseudoElement: "::view-transition-new(root)",
            },
          );
        });
        transition.finished.finally(() => root.classList.remove("theme-wipe"));
      });
    });
  }

  document.addEventListener("astro:page-load", init);
</script>
