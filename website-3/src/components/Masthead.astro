<div class="border-b border-line">
  <div
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-6 py-2 text-[11px] tracking-[0.18em] text-ink-muted uppercase"
  >
    <time data-masthead-date></time>
    <button
      type="button"
      data-theme-toggle
      aria-label="Toggle dark mode"
      class="flex items-center transition-colors hover:text-ink"
    >
      <span class="flex items-center gap-1.5 dark:hidden">
        <svg
          class="h-3 w-3"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M20.5 14.5A8.5 8.5 0 0 1 9.5 3.5a8.5 8.5 0 1 0 11 11Z"></path>
        </svg>
        Night edition
      </span>
      <span class="hidden items-center gap-1.5 dark:flex">
        <svg
          class="h-3 w-3"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4.2"></circle>
          <path
            d="M12 2.5v2.2M12 19.3v2.2M2.5 12h2.2M19.3 12h2.2M5.2 5.2l1.6 1.6M17.2 17.2l1.6 1.6M18.8 5.2l-1.6 1.6M6.8 17.2l-1.6 1.6"
          ></path>
        </svg>
        Day edition
      </span>
    </button>
  </div>
</div>
<script>
  const dateEl = document.querySelector("[data-masthead-date]");
  if (dateEl) {
    dateEl.textContent = new Intl.DateTimeFormat("en", {
      weekday: "long",
      month: "long",
      day: "numeric",
      year: "numeric",
    }).format(new Date());
  }

  const KEY = "ng-theme";
  const applyTheme = (dark: boolean) => {
    if (dark) document.documentElement.dataset.theme = "dark";
    else delete document.documentElement.dataset.theme;
    localStorage.setItem(KEY, dark ? "dark" : "light");
    document
      .querySelector('meta[name="theme-color"]')
      ?.setAttribute("content", dark ? "#161311" : "#faf9f5");
  };
  document.querySelectorAll("[data-theme-toggle]").forEach((btn) =>
    btn.addEventListener("click", () =>
      applyTheme(document.documentElement.dataset.theme !== "dark"),
    ),
  );
</script>
