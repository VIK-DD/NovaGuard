<section class="border-y border-line bg-surface">
  <dl
    data-stats
    class="mx-auto grid max-w-5xl grid-cols-2 gap-y-8 px-6 py-10 text-center sm:grid-cols-4"
    hidden
  >
    <div>
      <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Servers</dt>
      <dd data-stat="guilds" class="font-display mt-1 text-4xl">–</dd>
    </div>
    <div>
      <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Members</dt>
      <dd data-stat="members" class="font-display mt-1 text-4xl">–</dd>
    </div>
    <div>
      <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Commands</dt>
      <dd data-stat="commands" class="font-display mt-1 text-4xl">–</dd>
    </div>
    <div>
      <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Uptime</dt>
      <dd data-stat="uptime" class="font-display mt-1 text-4xl">–</dd>
    </div>
  </dl>
  <p
    data-stats-fallback
    class="mx-auto max-w-5xl px-6 py-8 text-center text-sm text-ink-muted"
  >
    Live numbers appear when the bot is online.
  </p>
</section>
<script>
  const base = import.meta.env.PUBLIC_API_BASE;
  const dl = document.querySelector<HTMLElement>("[data-stats]");
  const fb = document.querySelector<HTMLElement>("[data-stats-fallback]");
  const fmt = (n: number) => new Intl.NumberFormat("en").format(n);
  const dur = (s: number) =>
    s >= 86400
      ? `${Math.floor(s / 86400)}d`
      : s >= 3600
        ? `${Math.floor(s / 3600)}h`
        : `${Math.floor(s / 60)}m`;
  if (base && dl && fb) {
    fetch(`${base}/api/v1/stats`, { signal: AbortSignal.timeout(4000) })
      .then((r) => (r.ok ? r.json() : Promise.reject(r.status)))
      .then((s) => {
        const set = (k: string, v: string) => {
          const el = dl.querySelector(`[data-stat="${k}"]`);
          if (el) el.textContent = v;
        };
        set("guilds", fmt(s.guilds));
        set("members", fmt(s.members));
        set("commands", fmt(s.commands));
        set("uptime", dur(s.uptime_seconds));
        dl.hidden = false;
        fb.hidden = true;
      })
      .catch(() => {
        /* bot offline — fallback line stays */
      });
  }
</script>
