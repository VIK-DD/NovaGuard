---
---

<section data-perf-section data-stats-section class="mx-auto max-w-6xl px-5 sm:px-6">
  <dl
    data-stats
    data-reveal-group
    class="grid grid-cols-2 gap-3 sm:grid-cols-4"
    hidden
  >
    {
      [
        ["guilds", "Servers"],
        ["members", "Members"],
        ["commands", "Commands"],
        ["uptime", "Uptime"],
      ].map(([key, label]) => (
        <div
          data-reveal-item
          class="rounded-[var(--radius-card)] border border-line bg-card p-4 shadow-[0_1px_0_hsl(0_0%_100%/0.03)_inset] transition-colors hover:border-line-strong sm:p-5"
        >
          <dt class="text-[11px] tracking-[0.18em] text-ink-faint uppercase">{label}</dt>
          <dd
            data-stat={key}
            class="mt-1.5 font-display text-3xl font-semibold tabular-nums sm:text-4xl"
          >
            –
          </dd>
        </div>
      ))
    }
  </dl>
  <p
    data-stats-fallback
    class="rounded-[var(--radius-card)] border border-line bg-card px-6 py-5 text-center text-sm text-ink-muted"
  >
    Live numbers appear when the bot is online.
  </p>
</section>
<script>
  import { getLiveStats } from "../lib/api/liveStats";

  function init() {
    const dl = document.querySelector<HTMLElement>("[data-stats]");
    const fb = document.querySelector<HTMLElement>("[data-stats-fallback]");
    const fmt = (n: number) => new Intl.NumberFormat("en").format(Math.round(n));
    const dur = (s: number) =>
      s >= 86400
        ? `${Math.floor(s / 86400)}d`
        : s >= 3600
          ? `${Math.floor(s / 3600)}h`
          : `${Math.floor(s / 60)}m`;

    const loadStats = () => {
      if (!dl || !fb) return;

      getLiveStats()
        .then((s) => {
          const target = (k: string) => dl.querySelector(`[data-stat="${k}"]`);
          const gEl = target("guilds");
          const mEl = target("members");
          const cEl = target("commands");
          const uEl = target("uptime");
          if (gEl) gEl.textContent = fmt(s.guilds);
          if (mEl) mEl.textContent = fmt(s.members);
          if (cEl) cEl.textContent = fmt(s.commands);
          if (uEl) uEl.textContent = dur(s.uptime_seconds);
          dl.hidden = false;
          fb.hidden = true;
        })
        .catch(() => {});
    };

    const section = document.querySelector<HTMLElement>("[data-stats-section]");
    if (section && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (!entries[0]?.isIntersecting) return;
          observer.disconnect();
          loadStats();
        },
        { rootMargin: "240px 0px" },
      );
      observer.observe(section);
      return;
    }

    loadStats();
  }

  init();
</script>
