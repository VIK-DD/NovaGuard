---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = "NovaGuard — the friendly guardian for your Discord community.",
} = Astro.props;
// Dev-only: when PUBLIC_MOCK_API=1, load the in-memory API mock from <head> so
// its window.fetch patch is in place before any body script fires a request.
const mockEnabled = import.meta.env.DEV && import.meta.env.PUBLIC_MOCK_API === "1";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0c" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/favicon.png" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <script is:inline>
      // Dark-first: apply the stored/preferred theme before first paint (no flash).
      (() => {
        const stored = localStorage.getItem("ng-theme");
        const light = stored
          ? stored === "light"
          : matchMedia("(prefers-color-scheme: light)").matches;
        const root = document.documentElement;
        root.dataset.theme = light ? "light" : "dark";
        document
          .querySelector('meta[name="theme-color"]')
          ?.setAttribute("content", light ? "#fbfbfe" : "#0a0a0c");
      })();
    </script>
    <ClientRouter />
    <script is:inline>
      // Under ClientRouter the swapped <html> loses its JS-set data-theme, so
      // re-apply the stored theme after each swap, before the frame paints.
      // Registered once (document survives swaps) to avoid stacking listeners.
      if (!window.__ngThemeSwap) {
        window.__ngThemeSwap = true;
        document.addEventListener("astro:after-swap", () => {
          const stored = localStorage.getItem("ng-theme");
          const light = stored
            ? stored === "light"
            : matchMedia("(prefers-color-scheme: light)").matches;
          document.documentElement.dataset.theme = light ? "light" : "dark";
          document
            .querySelector('meta[name="theme-color"]')
            ?.setAttribute("content", light ? "#fbfbfe" : "#0a0a0c");
        });
        // A navigation View Transition aborted by the browser (notably under
        // prefers-reduced-motion) rejects with InvalidStateError even though the
        // navigation completes. Swallow only that benign rejection.
        window.addEventListener("unhandledrejection", (e) => {
          const r = e.reason;
          if (r && r.name === "InvalidStateError" && /Transition was aborted/.test(r.message || "")) {
            e.preventDefault();
          }
        });
      }
    </script>
    {
      mockEnabled && (
        <>
          <script
            is:inline
            set:html={`(() => {
  if (window.__ngMockReady) return;
  window.__ngMockReady = new Promise((r) => (window.__ngMockResolve = r));
  const real = window.fetch.bind(window);
  window.fetch = (input, init) => {
    const url = typeof input === "string" ? input : (input && (input.url || input.href)) || "";
    if (!url.includes("/api/v1")) return real(input, init);
    return window.__ngMockReady.then((h) => h(input, init, real));
  };
})();`}
          />
          <script>import "../lib/api/mock";</script>
        </>
      )
    }
  </head>
  <body class="min-h-screen bg-background font-sans text-ink">
    <div id="scroll-progress" aria-hidden="true"></div>
    <slot />
    <script>
      import "../scripts/motion";
    </script>
  </body>
</html>
