---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Status — NovaGuard" description="Live operational status of the NovaGuard bot.">
  <Nav />
  <main data-status-page class="mx-auto max-w-2xl px-5 py-12 sm:px-6 sm:py-20">
    <p class="text-xs tracking-[0.25em] text-ink-muted uppercase">System bulletin</p>
    <h1 data-status-headline class="font-display mt-4 text-3xl leading-tight sm:text-5xl">
      Taking the pulse…
    </h1>
    <p data-status-sub class="mt-4 text-ink-muted">Checking the bot's vital signs.</p>

    <dl class="mt-12">
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Status</dt>
        <dd class="flex shrink-0 items-center gap-2">
          <span data-status-dot class="h-2 w-2 rounded-full bg-line"></span>
          <span data-f="status" class="font-display text-lg sm:text-xl">—</span>
        </dd>
      </div>
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Version</dt>
        <dd data-f="version" class="font-display text-lg sm:text-xl">—</dd>
      </div>
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Uptime</dt>
        <dd data-f="uptime" class="font-display text-lg tabular-nums sm:text-xl">—</dd>
      </div>
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Servers</dt>
        <dd data-f="guilds" class="font-display text-lg sm:text-xl">—</dd>
      </div>
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Members</dt>
        <dd data-f="members" class="font-display text-lg sm:text-xl">—</dd>
      </div>
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Commands</dt>
        <dd data-f="commands" class="font-display text-lg sm:text-xl">—</dd>
      </div>
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Database</dt>
        <dd data-f="database" class="font-display text-lg sm:text-xl">—</dd>
      </div>
      <div class="flex items-baseline justify-between gap-4 border-t border-line py-4">
        <dt class="text-xs tracking-[0.2em] text-ink-muted uppercase">Gateway</dt>
        <dd data-f="gateway" class="font-display text-lg sm:text-xl">—</dd>
      </div>
    </dl>

    <p data-status-checked class="mt-6 text-xs tracking-wide text-ink-muted"></p>
  </main>
  <Footer />
</Base>

<script>
  import "../scripts/status";
</script>
