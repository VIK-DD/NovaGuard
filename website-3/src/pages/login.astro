---
import Base from "../layouts/Base.astro";
// Static page: ?next / ?error are read client-side (see script) since the
// gate is enforced by the Cloudflare Worker, not at build time.
---

<Base
  title="Private access — NovaGuard"
  description="NovaGuard is in private access. Enter your password to continue."
>
  <main class="grid min-h-screen place-items-center px-6 py-16">
    <section class="w-full max-w-sm text-center" aria-label="NovaGuard private access">
      <a href="/" class="inline-flex items-center gap-2.5" aria-label="NovaGuard home">
        <img src="/favicon.png" alt="" width="36" height="36" class="h-9 w-9" />
        <span class="font-display text-2xl font-semibold tracking-tight">NovaGuard</span>
      </a>

      <p class="mt-8 font-mono text-xs tracking-[0.35em] text-primary uppercase">Private access</p>
      <h1 class="font-display mt-3 text-3xl">Enter your password to continue.</h1>

      <form action="/api/auth/login" method="post" class="mt-8 text-left" id="login-form">
        <input type="hidden" name="next" id="next" value="/home/" />
        <label for="password" class="text-xs tracking-[0.15em] text-ink-muted uppercase">
          Password
        </label>
        <div class="relative mt-1.5">
          <span class="pointer-events-none absolute top-1/2 left-3 -translate-y-1/2 text-ink-faint">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </span>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="current-password"
            required
            placeholder="Enter password"
            class="w-full rounded-[8px] border border-line bg-card py-3 pr-11 pl-10 text-sm outline-none transition-colors focus:border-primary"
          />
          <button
            type="button"
            id="toggle-pw"
            aria-label="Show password"
            class="absolute top-1/2 right-2 grid h-8 w-8 -translate-y-1/2 place-items-center rounded-[6px] text-ink-faint transition-colors hover:text-ink"
          >
            <svg id="eye" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
            <svg id="eye-off" class="hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49"/><path d="M14.084 14.158a3 3 0 0 1-4.242-4.242"/><path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143"/><path d="m2 2 20 20"/></svg>
          </button>
        </div>
        <p id="pw-error" role="alert" class="mt-2 hidden text-xs text-primary">Password not accepted.</p>
        <button
          type="submit"
          id="submit"
          class="mt-5 flex w-full items-center justify-center gap-2 rounded-[8px] bg-primary py-3 text-sm font-medium text-primary-ink transition-opacity hover:opacity-90"
        >
          <span id="submit-label">Continue</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </button>
      </form>

      <p class="mt-10 text-xs text-ink-faint">Developed by VIK &amp; CloudMediaSRL</p>
    </section>
  </main>
</Base>

<script>
  const params = new URLSearchParams(window.location.search);
  const candidate = params.get("next") || "/home/";
  const next = candidate.startsWith("/") && !candidate.startsWith("//") ? candidate : "/home/";
  const nextInput = document.getElementById("next") as HTMLInputElement | null;
  if (nextInput) nextInput.value = next;

  if (params.get("error") === "1") {
    const err = document.getElementById("pw-error");
    const pw = document.getElementById("password");
    err?.classList.remove("hidden");
    pw?.setAttribute("aria-invalid", "true");
    (pw as HTMLInputElement | null)?.focus();
  } else {
    (document.getElementById("password") as HTMLInputElement | null)?.focus();
  }

  const toggle = document.getElementById("toggle-pw");
  const pwField = document.getElementById("password") as HTMLInputElement | null;
  toggle?.addEventListener("click", () => {
    if (!pwField) return;
    const show = pwField.type === "password";
    pwField.type = show ? "text" : "password";
    document.getElementById("eye")?.classList.toggle("hidden", show);
    document.getElementById("eye-off")?.classList.toggle("hidden", !show);
    toggle.setAttribute("aria-label", show ? "Hide password" : "Show password");
  });

  document.getElementById("login-form")?.addEventListener("submit", () => {
    const label = document.getElementById("submit-label");
    if (label) label.textContent = "Checking…";
    document.getElementById("submit")?.setAttribute("disabled", "true");
  });
</script>
