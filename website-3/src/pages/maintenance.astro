---
import Base from "../layouts/Base.astro";
---

<Base
  title="Update in progress — NovaGuard"
  description="NovaGuard private routes are temporarily in maintenance."
>
  <main class="grid min-h-screen place-items-center px-5 py-10 sm:px-6 sm:py-16">
    <section class="w-full max-w-xl text-center" aria-label="NovaGuard update in progress">
      <a href="/" class="inline-flex items-center gap-3" aria-label="NovaGuard home">
        <img src="/favicon.png" alt="" width="44" height="44" class="h-11 w-11 rounded-[10px]" />
        <span class="font-display text-3xl font-semibold tracking-tight">NovaGuard</span>
      </a>

      <p class="mt-8 font-mono text-xs tracking-[0.28em] text-primary uppercase sm:mt-10 sm:tracking-[0.35em]">
        Update in progress
      </p>
      <h1 class="font-display mx-auto mt-4 max-w-lg text-4xl leading-[0.98] tracking-tight sm:text-6xl">
        We are rebuilding this space.
      </h1>
      <p class="mx-auto mt-5 max-w-md text-base leading-7 text-ink-muted">
        Protected pages are paused while the next NovaGuard update is being polished.
      </p>

      <a
        href="/api/auth/logout"
        class="mt-9 inline-flex rounded-[8px] border border-line px-4 py-2 text-sm text-ink-muted transition-colors hover:border-line-strong hover:text-ink"
      >
        Sign out
      </a>

      <p class="mt-10 text-xs text-ink-faint">Developed by VIK &amp; CloudMedia</p>
    </section>
  </main>
</Base>
