TOKEN=your_discord_bot_token_here

# Optional but strongly recommended for instant slash-command sync in one server.
GUILD_ID=1454829495021338842

# GitHub integration
GITHUB_USERNAME=VIK-DD
GITHUB_PRIMARY_REPO=VIK-DD/NovaGuard
GITHUB_WATCH_REPOS=VIK-DD/NovaGuard
GITHUB_TOKEN=your_github_token_here
GITHUB_POLL_SECONDS=300

# Optional channel fallbacks for your main server
UPDATE_CHANNEL_ID=
GITHUB_EVENT_CHANNEL_ID=
ERROR_LOG_CHANNEL_ID=

# Optional extras
UPTIME_URL=
BOT_BRAND=NovaGuard
STREAM_STATUSES=Watching late-night commits|I'll never forget that July|/help • the slash era|Shipping updates automatically
STREAM_STATUS_INTERVAL_SECONDS=15

# Optional AI support
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Web dashboard API (setup from the website)
# 1. Discord Developer Portal -> your app -> OAuth2 -> add redirect:
#    http://localhost:8300/api/auth/callback  (or your public URL)
# 2. Copy the Client ID + Client Secret below and set WEB_ENABLED=true
WEB_ENABLED=false
WEB_PORT=8300
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
WEB_OAUTH_REDIRECT=http://localhost:8300/api/auth/callback
# Where the browser lands after login (your dashboard page)
WEB_AFTER_LOGIN=/api/me
# Allowed browser origins (comma-separated). Empty = same-origin only, never a
# wildcard. Example: https://novaguard.app,https://www.novaguard.app
WEB_CORS_ORIGIN=
# Set true when serving through HTTPS (Cloudflare Tunnel etc.)
WEB_COOKIE_SECURE=false
# Set true when behind a reverse proxy / Cloudflare Tunnel so rate limits and
# the audit trail see the real visitor IP (CF-Connecting-IP / X-Forwarded-For).
WEB_TRUST_PROXY=false
# Optional: key for encrypting OAuth tokens at rest. Defaults to the client
# secret; set a separate value to rotate independently. Requires `cryptography`.
WEB_TOKEN_KEY=
